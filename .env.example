# Copy this file to .env and fill in your values.

# Your OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Django secret key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-long-random-secret-key

# Comma-separated list of hostnames Django will serve (no scheme)
ALLOWED_HOSTS=virtualreviewer.digi-teach.com,localhost

# Comma-separated list of trusted origins for CSRF (include scheme)
CSRF_TRUSTED_ORIGINS=https://virtualreviewer.digi-teach.com,http://localhost:8000
